generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String       @id
  email        String?      @unique
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  docs         Doc[]
  vocabularies Vocabulary[]
}

model Doc {
  id           String       @id @default(uuid())
  userId       String
  title        String
  sourceUrl    String
  siteName     String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  content      DocContent?
  vocabularies Vocabulary[]

  @@index([userId])
  @@index([createdAt])
}

model DocContent {
  id          String   @id @default(uuid())
  docId       String   @unique
  htmlContent String?
  textContent String
  wordCount   Int      @default(0)
  createdAt   DateTime @default(now())
  doc         Doc      @relation(fields: [docId], references: [id], onDelete: Cascade)
}

model Vocabulary {
  id               String   @id @default(uuid())
  userId           String
  docId            String?

  sourceUrl        String?
  sourceHostname   String?
  pageTitle        String?
  
  word             String
  meaning          String?
  note             String?
  originalSentence String?
  exampleSentence  String?
  status           String   @default("new")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  doc              Doc?     @relation(fields: [docId], references: [id])
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([docId])
  @@index([sourceUrl])
  @@index([sourceHostname])
  @@index([word])
}
